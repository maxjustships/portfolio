---
import Layout from '../layouts/Layout.astro';
import { PROJECTS, SMALL_TOOLS, CONTACT } from '../data/projects';
---

<Layout
  title="Max — I build and ship software products"
  description="Full-cycle software builder: web products, Telegram bots, browser extensions, and agent workflows. Everything is open source and verifiable on GitHub."
>
  <div class="relative">
    <!-- HERO -->
    <header class="relative overflow-hidden">
      <div class="portrait-backdrop" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-5xl px-6 pt-20 pb-16 md:pt-28 md:pb-24">
        <p class="text-sm font-semibold uppercase tracking-[0.25em] text-brand-orange">
          maxjustships.dev
        </p>
        <h1 class="font-display mt-4 max-w-2xl text-5xl md:text-6xl font-black leading-[1.05] tracking-tight">
          Max builds and ships software&nbsp;products.
        </h1>
        <p class="mt-6 max-w-xl text-lg md:text-xl leading-relaxed text-white/85">
          Full-cycle product development — web apps, Telegram bots, browser extensions,
          and agent workflows. From idea to deployed, working software.
        </p>
        <p class="mt-4 max-w-xl text-base leading-relaxed text-white/55">
          Everything below is live and open source — explore the products and the code behind them.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="#projects"
            class="brutal-button bg-brand-orange px-6 py-3 text-sm font-bold uppercase tracking-wide text-black"
          >
            View projects ↓
          </a>
          <a
            href={CONTACT.github}
            target="_blank"
            rel="noopener"
            class="brutal-button bg-black px-6 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-white hover:text-black"
          >
            See the code →
          </a>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6">
      <!-- WHAT I DO -->
      <section class="border-t-2 border-white/15 py-14">
        <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight">
          What I do
        </h2>
        <div class="mt-8 grid gap-6 md:grid-cols-3">
          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-brand-orange">Products</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/70">
              Web products and PWAs designed for daily use — fast, accessible, and deployed.
            </p>
          </div>
          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-brand-blue">Platforms</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/70">
              Telegram bots and serverless backends on Cloudflare Workers, D1, and modern tooling.
            </p>
          </div>
          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-brand-orange">Workflows</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/70">
              Agent-driven pipelines and browser extensions that remove friction from real work.
            </p>
          </div>
        </div>
      </section>

      <!-- PROJECTS -->
      <section id="projects" class="border-t-2 border-white/15 py-14 scroll-mt-8">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight">
            Selected projects
          </h2>
          <a
            href={CONTACT.github}
            target="_blank"
            rel="noopener"
            class="text-sm font-semibold text-white/60 underline decoration-brand-orange decoration-2 underline-offset-4 hover:text-white"
          >
            All repositories on GitHub →
          </a>
        </div>

        <div class="mt-10 grid gap-10">
          {PROJECTS.map((project) => (
            <article class="brutal-card bg-black">
              <div class="flex flex-col md:flex-row">
                <div class="border-b-3 md:border-b-0 md:border-r-3 border-white md:w-2/5">
                  {project.image ? (
                    <img
                      src={project.image}
                      alt={`${project.title} screenshot`}
                      class="h-full w-full object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div
                      class={`flex h-48 md:h-full items-center justify-center ${
                        project.color === 'orange' ? 'bg-brand-orange' : 'bg-brand-blue'
                      }`}
                      aria-hidden="true"
                    >
                      <span class="font-display text-6xl md:text-7xl font-black tracking-tight text-black">
                        {project.monogram}
                      </span>
                    </div>
                  )}
                </div>
                <div class="flex flex-1 flex-col justify-between p-6 md:p-8">
                  <div>
                    <h3 class="font-display text-2xl md:text-3xl font-black tracking-tight">
                      {project.title}
                    </h3>
                    <p class="mt-3 text-sm font-semibold uppercase tracking-wider text-white/50">
                      {project.problem}
                    </p>
                    <p class="mt-3 leading-relaxed text-white/80">{project.solution}</p>
                    <ul class="mt-4 flex flex-wrap gap-2">
                      {project.stack.map((tech) => (
                        <li class="border border-white/40 px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-white/70">
                          {tech}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="mt-6 flex flex-wrap gap-3">
                    <a
                      href={project.live}
                      target="_blank"
                      rel="noopener"
                      class={`brutal-button px-5 py-2 text-xs font-bold uppercase tracking-wide text-black ${
                        project.color === 'orange' ? 'bg-brand-orange' : 'bg-brand-blue'
                      }`}
                    >
                      {project.liveLabel} →
                    </a>
                    <a
                      href={project.source}
                      target="_blank"
                      rel="noopener"
                      class="brutal-button bg-black px-5 py-2 text-xs font-bold uppercase tracking-wide text-white hover:bg-white hover:text-black"
                    >
                      Source
                    </a>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- SMALL TOOLS -->
      <section class="border-t-2 border-white/15 py-14">
        <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight">
          Small tools
        </h2>
        <p class="mt-3 text-sm text-white/60">
          Utilities I built for myself and shipped anyway.
        </p>
        <ul class="mt-8 grid gap-4 md:grid-cols-2">
          {SMALL_TOOLS.map((tool) => (
            <li class="border-2 border-white/25 p-5 transition-colors hover:border-white">
              <a href={tool.url} target="_blank" rel="noopener" class="group block">
                <h3 class="font-display text-lg font-bold group-hover:text-brand-orange">
                  {tool.title} <span class="text-white/40">→</span>
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-white/70">{tool.line}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- ABOUT -->
      <section class="border-t-2 border-white/15 py-14">
        <div class="flex flex-col items-start gap-8 md:flex-row md:items-center">
          <img
            src="/assets/photo.png"
            alt="Portrait of Max"
            class="h-40 w-40 shrink-0 border-3 border-white object-cover bg-white"
            loading="lazy"
          />
          <div>
            <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight">
              About
            </h2>
            <p class="mt-4 max-w-2xl leading-relaxed text-white/80">
              I'm Max. I build software products end to end — from the first sketch
              to deployment and maintenance. I work in the open: most of what I ship
              is public on GitHub, with CI, docs, and a real URL behind it.
            </p>
            <p class="mt-3 max-w-2xl leading-relaxed text-white/60">
              If you're building something and need someone who ships — let's talk.
            </p>
          </div>
        </div>
      </section>
    </main>

    <!-- CONTACT / FOOTER -->
    <footer class="border-t-2 border-white/15">
      <div class="mx-auto max-w-5xl px-6 py-14">
        <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight">
          Let's talk
        </h2>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href={CONTACT.telegram}
            target="_blank"
            rel="noopener"
            class="brutal-button bg-brand-orange px-6 py-3 text-sm font-bold uppercase tracking-wide text-black"
          >
            Telegram {CONTACT.telegramLabel} →
          </a>
          <a
            href={`mailto:${CONTACT.email}`}
            class="brutal-button bg-black px-6 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-white hover:text-black"
          >
            {CONTACT.email}
          </a>
          <a
            href={CONTACT.github}
            target="_blank"
            rel="noopener"
            class="brutal-button bg-black px-6 py-3 text-sm font-bold uppercase tracking-wide text-white hover:bg-white hover:text-black"
          >
            GitHub →
          </a>
        </div>
        <p class="mt-12 text-xs uppercase tracking-widest text-white/40">
          © 2026 Max · maxjustships.dev · Build. Ship. Repeat.
        </p>
      </div>
    </footer>
  </div>
</Layout>
